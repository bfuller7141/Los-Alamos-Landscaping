---
import TestimonialCard from "./TestimonialCard.astro";

interface Props {
  limit?: number;
  showAllButton?: boolean;
}

const { limit = 5, showAllButton = true } = Astro.props as Props;

// Import and eagerly load testimonials
const testimonials = import.meta.glob("../content/testimonials/*.md", { eager: true });

// Shuffle the array of testimonials
function shuffleArray(array: any[]) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

const parsedTestimonials = Object.entries(testimonials).map(([path, module]) => {
  if (typeof module === 'object' && module !== null) {
    return {
      ...module,
      slug: path.split("/").pop()?.replace(".md", ""),
    };
  }
  return {
    slug: path.split("/").pop()?.replace(".md", ""),
  };
});

const shuffledTestimonials = shuffleArray(parsedTestimonials);
const displayedTestimonials = limit > 0 ? shuffledTestimonials.slice(0, limit) : shuffledTestimonials;
const isLimitedLayout = limit > 0;
const useBentoLayout = isLimitedLayout && displayedTestimonials.length >= 5;
---
<div class="testimonial-container">
    <ul class:list={["testimonial-grid", { "is-bento": useBentoLayout }]}>
        {displayedTestimonials.map((testimonial) => (
            <li>
                <TestimonialCard
                    rating={testimonial.frontmatter.rating}
                    name={testimonial.frontmatter.name}
                    testimonial={testimonial.frontmatter.testimonial}
                />
            </li>
        ))}
    </ul>
    <div class="testimonial-slider">
        <div class="testimonial-slider-wrapper">
            {displayedTestimonials.map((testimonial) => (
                <div class="testimonial-card-wrapper">
                    <TestimonialCard
                        rating={testimonial.frontmatter.rating}
                        name={testimonial.frontmatter.name}
                        testimonial={testimonial.frontmatter.testimonial}
                    />
                </div>
            ))}
        </div>
        <div class="testimonial-dots">
          {displayedTestimonials.map((testimonial, index) => (
            <div class="testimonial-dot" data-index={index}></div>
          ))}
        </div>
    </div>

    {showAllButton && (
        <div class="btn-wrapper center testimonials-cta">
            <a href="/reviews" class="btn-primary">View All Reviews</a>
        </div>
    )}
</div>

<style>
    .testimonial-container {
        width: 100%;
    }

    .testimonial-grid {
        column-count: 3;
        column-gap: 2rem;
        padding: 0;
        margin: 3rem 0 0 0;
        list-style: none;
        position: relative;
    }

    .testimonial-grid li {
        break-inside: avoid;
        margin: 0 0 2rem;
        width: 100%;
    }

    .testimonial-grid.is-bento {
        column-count: initial;
        column-gap: 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        grid-template-areas:
            "left-top center right-top"
            "left-bottom center right-bottom";
        gap: 2rem;
        align-items: stretch;
    }

    .testimonial-grid.is-bento li {
        break-inside: initial;
        margin: 0;
        display: flex;
    }

    .testimonial-grid.is-bento li:nth-child(1) { grid-area: left-top; }
    .testimonial-grid.is-bento li:nth-child(2) { grid-area: left-bottom; }
    .testimonial-grid.is-bento li:nth-child(3) { grid-area: center; }
    .testimonial-grid.is-bento li:nth-child(4) { grid-area: right-top; }
    .testimonial-grid.is-bento li:nth-child(5) { grid-area: right-bottom; }

    @media screen and (max-width: 1200px) {
        .testimonial-grid {
            column-count: 2;
        }

        .testimonial-grid.is-bento {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            grid-template-areas: none;
            gap: 1.5rem;
        }

        .testimonial-grid.is-bento li {
            grid-area: auto !important;
        }
    }
    /* Slider Layout for Smaller Screens */
    @media screen and (max-width: 867px) {
    .testimonial-grid {
        display: none;
    }

    .testimonial-slider {
        display: block;
        overflow: hidden;
    }

    .testimonial-slider-wrapper {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    .testimonial-card-wrapper {
        flex: 0 0 auto;
        width: 90%;
        scroll-snap-align: center;
        box-sizing: border-box;
    }

    .testimonial-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .testimonial-dot {
        width: 10px;
        height: 10px;
        background-color: var(--red-100);
        border-radius: 50%;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .testimonial-dot.active {
        background-color: var(--red-500);
    }
    }

    .testimonials-cta {
        margin-top: 1rem;
    }

/* Hide slider for larger screens */
  @media screen and (min-width: 868px) {
    .testimonial-slider {
      display: none;
    }
  }

/* Hide scrollbar */
  @media screen and (max-width: 867px) {
    .testimonial-slider {
      display: block;
      overflow: hidden;
    }

    .testimonial-slider-wrapper {
      display: flex;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      gap: 1rem;
      scroll-behavior: smooth;
      -ms-overflow-style: none; /* IE and Edge */
      scrollbar-width: none; /* Firefox */
    }

    .testimonial-slider-wrapper::-webkit-scrollbar {
      display: none; /* Chrome, Safari, Opera */
    }
  }
</style>
